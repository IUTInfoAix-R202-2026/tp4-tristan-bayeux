{
    "java.server.launchMode": "Standard",
    "java.configuration.updateBuildConfiguration": "automatic",
    "java.compile.nullAnalysis.mode": "automatic",
    "//": "vmArgs par defaut pour tout Run/Debug Java du workspace (l'extension Java ne lit ni le plugin javafx ni Surefire). Couvre l'acces natif JavaFX et les ouvertures de modules.",
    "java.debug.settings.vmArgs": "--enable-native-access=ALL-UNNAMED --enable-native-access=javafx.graphics --add-reads javafx.graphics=ALL-UNNAMED --add-opens javafx.graphics/com.sun.javafx.application=ALL-UNNAMED --add-opens javafx.base/com.sun.javafx.runtime=ALL-UNNAMED --add-exports javafx.graphics/com.sun.javafx.application=ALL-UNNAMED --sun-misc-unsafe-memory-access=allow",
    "git.autofetch": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "files.exclude": {
        "**/target": true,
        "**/.idea": true,
        "**/*.iml": true
    },
    "github.copilot.enable": {
        "*": false
    },
    "chat.tools.terminal.outputLocation": "terminal",
    "chat.tools.terminal.autoApprove": {
        "./mvnw": true,
        "./sync-upstream.sh": true,
        "./grade-test.sh": true,
        "/^git\\s+checkout\\b/": true,
        "/^git\\s+add\\b/": true,
        "/^git\\s+commit\\b/": true,
        "/^git\\s+push\\b/": true,
        "/^git\\s+pull\\b/": true,
        "/^git\\s+stash\\b/": true,
        "/^gh\\s+pr\\b/": true
    }
}
